# Copy this file to `.env` and adjust for your machine.
# `.env` is gitignored so real credentials never reach the repository.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tracker_db
DB_USER=tracker_app
# Local development password created by sql/schema.sql.
# Use a strong, unique value for any real deployment.
DB_PASS=tracker_dev_pwd

# development | production  (production hides error details)
APP_ENV=development
